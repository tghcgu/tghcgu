# Discord Bot Token (https://discord.com/developers/applications からコピー)
DISCORD_TOKEN=your_bot_token_here

# Application ID (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=your_client_id_here

# ギルドID（開発用。本番はこの行を削除するとグローバル登録になります）
# GUILD_ID=your_guild_id_here

# Web UIのポート番号（デフォルト: 3000）
WEB_PORT=3000
